# ─── Banco de dados SQL Server ────────────────────────────────────────────────
# Exemplo para instância local padrão:
DB_SERVER=localhost
# Para instância nomeada:
# DB_SERVER=localhost\\MSSQLSERVER
DB_DATABASE=polpa_brasil
DB_USER=sa
DB_PASSWORD=SuaSenhaSQLServer
DB_PORT=1433
DB_ENCRYPT=false

# ─── Autenticação ─────────────────────────────────────────────────────────────
COOKIE_SECRET=troque_por_uma_string_aleatoria_longa_e_segura

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=5000
